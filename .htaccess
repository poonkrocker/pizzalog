# ============================================================
#  pizzalog.net (raíz) — sirve La Carta: pizzalog.net/{slug}
# ============================================================
# Nunca exponer .git ni ningún archivo/carpeta oculto
RedirectMatch 404 /\.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  # Lo que no sea un archivo o carpeta real es un slug -> la carta
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "(config\.js|index\.html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
